# ============================================================
# Weather Data ETL Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- OpenWeatherMap API ---
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5/weather

# Cities to monitor (comma-separated, must be valid OWM city names)
# These 5 Indian metros generate ~10K records/day across the pipeline
CITIES=Ahmedabad,Mumbai,Delhi,Bengaluru,Chennai

# --- PostgreSQL ---
# Use port 5433 when accessing from host (Docker maps 5433 → 5432 inside container)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=weather_warehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=vanshdb

# --- Airflow ---
AIRFLOW_HOME=/path/to/airflow
DAG_ID=weather_etl_pipeline_v2
# Daily run at 02:00 UTC (cron syntax)
SCHEDULE_INTERVAL=0 2 * * *

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/etl_pipeline.log
